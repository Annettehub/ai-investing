---
interface Props {
  sublist: any[];
  nested?: boolean;
}

const { sublist, nested } = Astro.props;

function flattenSidebar(entries: any[]): any[] {
  return entries.flatMap((entry) => (entry.type === 'group' ? flattenSidebar(entry.entries) : entry));
}

function splitOverview(entry: any) {
  const [first, ...rest] = entry.entries;
  if (first?.type === 'link' && first.label === '总览') {
    return { overview: first, entries: rest };
  }
  return { overview: undefined, entries: entry.entries };
}

function isSectionIndex(entry: any) {
  return ['总索引', 'Hypotheses 假设判断层', '输出总览'].includes(entry.label);
}
---

<ul class:list={{ 'top-level': !nested }}>
  {
    sublist.map((entry) => (
      <li>
        {entry.type === 'link' ? (
          <a
            href={entry.href}
            aria-current={entry.isCurrent ? 'page' : undefined}
            class:list={[{ large: !nested, 'section-index': isSectionIndex(entry) }, entry.attrs.class]}
            {...entry.attrs}
          >
            <span>{entry.label}</span>
          </a>
        ) : (
          (() => {
            const { overview, entries } = splitOverview(entry);
            return (
              <details
                open={flattenSidebar(entry.entries).some((i) => i.isCurrent) || !entry.collapsed}
              >
                <summary>
                  <span class="group-label">
                    {overview ? (
                      <a
                        class="group-link large"
                        href={overview.href}
                        aria-current={overview.isCurrent ? 'page' : undefined}
                        onclick="event.stopPropagation()"
                      >
                        {entry.label}
                      </a>
                    ) : (
                      <span class="large">{entry.label}</span>
                    )}
                  </span>
                  <span class="caret" aria-hidden="true">›</span>
                </summary>
                <Astro.self sublist={entries} nested />
              </details>
            );
          })()
        )}
      </li>
    ))
  }
</ul>

<style>
  @layer starlight.core {
    ul {
      --sl-sidebar-item-padding-inline: 0.5rem;
      list-style: none;
      padding: 0;
    }

    li {
      overflow-wrap: anywhere;
    }

    ul ul li {
      margin-inline-start: var(--sl-sidebar-item-padding-inline);
      border-inline-start: 1px solid var(--sl-color-hairline-light);
      padding-inline-start: var(--sl-sidebar-item-padding-inline);
    }

    .large {
      font-size: var(--sl-text-lg);
      font-weight: 600;
      color: var(--sl-color-white);
    }

    .top-level > li + li {
      margin-top: 0.75rem;
    }

    summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.2em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
      cursor: pointer;
      user-select: none;
    }

    summary::marker,
    summary::-webkit-details-marker {
      display: none;
    }

    .caret {
      transition: transform 0.2s ease-in-out;
      flex-shrink: 0;
    }

    :global([dir='rtl']) .caret {
      transform: rotateZ(180deg);
    }

    [open] > summary .caret {
      transform: rotateZ(90deg);
    }

    a {
      display: block;
      border-radius: 0.25rem;
      text-decoration: none;
      color: var(--sl-color-gray-2);
      padding: 0.3em var(--sl-sidebar-item-padding-inline);
      line-height: 1.4;
    }

    .group-link {
      display: inline-block;
      padding: 0;
    }

    .section-index {
      margin-block: 0.1rem;
      color: var(--sl-color-white);
      font-size: var(--sl-text-base);
      font-weight: 600;
    }

    a:hover,
    a:focus {
      color: var(--sl-color-white);
    }

    [aria-current='page'],
    [aria-current='page']:hover,
    [aria-current='page']:focus {
      font-weight: 600;
      color: var(--sl-color-text-invert);
      background-color: var(--sl-color-text-accent);
    }

    .group-link[aria-current='page'],
    .group-link[aria-current='page']:hover,
    .group-link[aria-current='page']:focus {
      color: var(--sl-color-text-accent);
      background-color: transparent;
    }

    a > *:not(:last-child),
    .group-label > *:not(:last-child) {
      margin-inline-end: 0.25em;
    }

    @media (min-width: 50rem) {
      .top-level > li + li {
        margin-top: 0.5rem;
      }

      .large {
        font-size: var(--sl-text-base);
      }

      a {
        font-size: var(--sl-text-sm);
      }
    }
  }
</style>
