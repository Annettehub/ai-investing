# 小苔花投研 — 环境配置
# 复制此文件为 .env 并填入实际的 API Key
# cp config/.env.example config/.env

# 行情数据源（至少填一个）
# Financial Modeling Prep — 免费注册: https://site.financialmodelingprep.com/developer
# 免费版每天 250 次请求，足够个人使用
FMP_API_KEY=

# Tushare — A股/港股行情（推荐用于 00981.HK 等港股）
# 注册: https://tushare.pro/ → 需要积分才能调用 hk_daily
TUSHARE_TOKEN=

# 可选兜底数据源
# FINNHUB_API_KEY=
# EOD_API_KEY=

# 启用 yfinance 作为最终兜底（需要 pip install yfinance）
# ENABLE_YFINANCE=1

# H1.2 存储研究驾驶舱
# SEC公开API无需密钥，但官方要求User-Agent标明使用者；建议填入联系邮箱。
SEC_USER_AGENT=AnnetteKnowledgeHub/0.1 your-email@example.com

# 韩国OpenDART：用于Samsung Electronics、SK Hynix披露监控
# 申请：https://opendart.fss.or.kr/
OPENDART_API_KEY=
