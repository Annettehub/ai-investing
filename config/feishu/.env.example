# 飞书 API 配置
# 从飞书开发者平台获取：https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书同步文件夹 token
# 从文件夹 URL 中提取：https://my.feishu.cn/drive/folder/{folder_token}
FEISHU_FOLDER_TOKEN=LsWZfobhDlImj0dEm47cJGFmn0Z

# 推送目标目录（相对于仓库根目录）
TARGET_DIR=02-kb/sources/feishu

# 同步模式：incremental=增量（默认）, full=全量
SYNC_MODE=incremental
